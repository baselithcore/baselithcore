# BaselithCore — environment template
# Copy to .env and fill in REAL values. NEVER commit .env (gitignored).
# All secrets MUST be rotated if exposed.

# ── Core ──────────────────────────────────────────────────────────────────
CORE_APP_NAME=baselith-core
CORE_DEBUG=false
CORE_MAX_WORKERS=4
CORE_PLUGIN_DIR=./plugins
CORE_DATA_DIR=./data
CORE_DOCUMENTS_DIR=./documents
CORE_DETERMINISTIC_MODE=false
CORE_RANDOM_SEED=42
PORT=8000

# ── LLM provider ──────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_API_KEY=__CHANGE_ME__
LLM_API_BASE=
LLM_ENABLE_CACHE=true
LLM_CACHE_TTL=3600
LLM_CACHE_MAX_SIZE=1000
LLM_HUGGINGFACE_LOCAL=false
LLM_HUGGINGFACE_DEVICE=cpu
LLM_HUGGINGFACE_DTYPE=float16
LLM_HUGGINGFACE_TRUST_REMOTE_CODE=false
HF_TOKEN=__CHANGE_ME__

# ── Vision ────────────────────────────────────────────────────────────────
VISION_PROVIDER=openai
VISION_OPENAI_API_KEY=__CHANGE_ME__
VISION_ANTHROPIC_API_KEY=__CHANGE_ME__
VISION_GOOGLE_API_KEY=__CHANGE_ME__
VISION_OLLAMA_HOST=http://localhost:11434
VISION_OLLAMA_MODEL=llava

# ── Voice ─────────────────────────────────────────────────────────────────
VOICE_PROVIDER=openai
VOICE_OPENAI_API_KEY=__CHANGE_ME__
VOICE_ELEVENLABS_API_KEY=__CHANGE_ME__
VOICE_GOOGLE_API_KEY=__CHANGE_ME__
VOICE_GOOGLE_APPLICATION_CREDENTIALS=

# ── Anthropic / Fine-tuning ───────────────────────────────────────────────
ANTHROPIC_API_KEY=__CHANGE_ME__
FINETUNE_OPENAI_API_KEY=__CHANGE_ME__
FINETUNE_TOGETHER_API_KEY=__CHANGE_ME__

# ── Vector store (Qdrant) ─────────────────────────────────────────────────
VECTORSTORE_PROVIDER=qdrant
VECTORSTORE_COLLECTION_NAME=baselith
VECTORSTORE_QDRANT_HOST=localhost
VECTORSTORE_PORT=6333
VECTORSTORE_GRPC_PORT=6334
VECTORSTORE_EMBEDDING_MODEL=text-embedding-3-small
VECTORSTORE_EMBEDDING_DIM=1536
EMBEDDING_CACHE_TTL=86400
VECTORSTORE_SEARCH_LIMIT=10
VECTORSTORE_QDRANT_MODE=server

# ── Chat ──────────────────────────────────────────────────────────────────
CHAT_STREAMING_ENABLED=true
CHAT_INITIAL_SEARCH_K=20
CHAT_FINAL_TOP_K=5
CHAT_MAX_HISTORY_LENGTH=20
CHAT_ENABLE_RERANKING=false
CHAT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHAT_RERANK_MAX_CANDIDATES=20
CHAT_ENABLE_RESPONSE_CACHE=true
CHAT_RESPONSE_CACHE_TTL=300

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baselith
DB_USER=baselith
DB_PASSWORD=__CHANGE_ME__
DB_SSL_MODE=require
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30

# ── Graph DB ──────────────────────────────────────────────────────────────
GRAPH_DB_ENABLED=false
GRAPH_DB_URL=bolt://localhost:7687
GRAPH_DB_NAME=neo4j
GRAPH_RAG_ENABLED=false
GRAPH_DB_TIMEOUT=30
GRAPH_SIMILAR_TOP_K=5
GRAPH_CACHE_TTL=3600
GRAPH_QUERY_LIMIT=100
GRAPH_MAX_HOPS=3
GRAPH_QUERY_TIMEOUT=10

# ── Cache / Queue (Redis) ─────────────────────────────────────────────────
CACHE_BACKEND=redis
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_PREFIX=baselith:
QUEUE_REDIS_URL=redis://localhost:6379/1

# ── Document ingestion ────────────────────────────────────────────────────
DOCUMENTS_EXTENSIONS=pdf,docx,txt,md
WEB_DOCUMENTS_ENABLED=false
WEB_DOCUMENTS_URLS=
WEB_DOCUMENTS_MAX_PAGES=50
WEB_DOCUMENTS_MAX_DEPTH=2
WEB_DOCUMENTS_RENDER_TIMEOUT=30
WEB_DOCUMENTS_USER_AGENT=baselith-core/1.0
WEB_DOCUMENTS_ALLOWLIST=
ENABLE_SPACY_DOCUMENTS=false
SPACY_MODEL=en_core_web_sm
SPACY_FALLBACK_LANGUAGE=en

# ── OCR ───────────────────────────────────────────────────────────────────
# Backends: auto | mineru | tesseract. MinerU (primary) requires the extra:
#   pip install -e ".[mineru]"   (heavy; downloads models on first use —
#   pre-fetch with `mineru-models-download`)
PDF_OCR_BACKEND=tesseract
# MinerU engine: pipeline (CPU-ok) | vlm-engine | hybrid-engine |
# vlm-http-client | hybrid-http-client
MINERU_BACKEND=pipeline
# OCR language model: en/latin cover Latin-script languages (incl. Italian);
# others: ch, korean, japan, th, el, arabic, cyrillic, devanagari, ...
MINERU_LANG=en
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
# Remote inference server for *-http-client backends (e.g. http://mineru:30000)
MINERU_SERVER_URL=
# Model download source: huggingface | modelscope | local (empty = auto)
MINERU_MODEL_SOURCE=

# ── Logging / Telemetry ───────────────────────────────────────────────────
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=DEBUG
LOG_JSON=true
LOG_MASKING_ENABLED=true
# Directory for the JSON file sink (app.log). Empty ⇒ CWD-relative "logs/".
# Pin an ABSOLUTE path so the sink does not depend on the process working dir
# and lands on a writable, log-shipper-mounted volume (a Promtail scrape path,
# or a systemd ReadWritePaths dir under ProtectSystem=strict).
#   BASELITH_LOG_DIR=/var/log/baselithcore
BASELITH_LOG_DIR=
TELEMETRY_ENABLED=true
TELEMETRY_OTEL_ENDPOINT=http://localhost:4318
APP_TIMEZONE=UTC

# ── Features ──────────────────────────────────────────────────────────────
ENABLE_FEEDBACK=true
LLM_BUDGET_ENABLED=true
LLM_BUDGET_MAX_TOKENS=1000000
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_MAX_TURNS=10
CHAT_MEMORY_SUMMARY_ENABLED=true
CHAT_GUARDRAILS_ENABLED=true
CHAT_GUARDRAILS_BLOCK_MESSAGE=Content blocked by guardrails.
CHAT_GUARDRAILS_OUT_OF_SCOPE_MESSAGE=Out-of-scope request rejected.

# ── Plugins ───────────────────────────────────────────────────────────────
PLUGIN_ENABLED=true
PLUGIN_AUTO_LOAD=true
PLUGIN_CONFIG_PATH=./configs/plugins.yaml

# ── Sandbox ───────────────────────────────────────────────────────────────
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT=30
SANDBOX_ENABLE_NETWORK=false

# ── Tree-of-Thoughts ──────────────────────────────────────────────────────
TOT_MAX_DEPTH=4
TOT_BRANCHING_FACTOR=3
TOT_BEAM_WIDTH=3
TOT_STRATEGY=bfs
TOT_SELF_CORRECTION_MAX_ITERATIONS=2
TOT_THOUGHT_CACHE_MAXSIZE=1000
TOT_THOUGHT_CACHE_TTL=3600

# ── Resilience ────────────────────────────────────────────────────────────
RESILIENCE_CB_FAIL_MAX=5
RESILIENCE_CB_RESET_TIMEOUT=60
RESILIENCE_CB_HALF_OPEN_MAX=3
RESILIENCE_RETRY_MAX_ATTEMPTS=3
RESILIENCE_RETRY_BASE_DELAY=0.5
RESILIENCE_RETRY_MAX_DELAY=10
RESILIENCE_RETRY_EXPONENTIAL_BASE=2
RESILIENCE_RETRY_JITTER=0.1
RESILIENCE_BULKHEAD_MAX_CONCURRENT=10
RESILIENCE_API_RATE_LIMIT=100
RESILIENCE_API_RATE_WINDOW=60
RESILIENCE_LLM_RATE_LIMIT=20
RESILIENCE_LLM_RATE_WINDOW=60

# ── Auth / Security ───────────────────────────────────────────────────────
# SECRET_KEY MUST be >= 32 random bytes. Generate with: openssl rand -hex 32
AUTH_REQUIRED=true
SECRET_KEY=__CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32__
ALLOW_ORIGINS=https://app.example.com
API_KEYS_USER=__CHANGE_ME__
API_KEYS_ADMIN=__CHANGE_ME__
API_KEYS_JOB=__CHANGE_ME__
# Master switch for API-key auth. When false, API keys are rejected entirely.
API_KEY_ENABLED=true
ADMIN_USER=admin
ADMIN_PASS=__CHANGE_ME__
SENTRY_DSN=

# Plugin integrity: NEVER enable in production
BASELITH_SKIP_INTEGRITY_CHECK=false
# Reject any plugin that does not declare an integrity hash.
BASELITH_REQUIRE_SIGNED_PLUGINS=false

# ── Agent-to-Agent (A2A) ──────────────────────────────────────────────────
# HMAC-sign A2A traffic: set the SAME secret on every peer of the mesh. When
# set, requests with a missing/invalid/stale signature are rejected with 401.
BASELITH_A2A_SHARED_SECRET=
# With no shared secret the A2A dispatch endpoint FAILS CLOSED in production
# (unsigned requests -> 401). Set true ONLY to explicitly allow unauthenticated
# A2A in production (trusted network). No effect outside production.
BASELITH_A2A_ALLOW_UNAUTHENTICATED=false

# ── Red Agent (security testing) ──────────────────────────────────────────
RED_AGENT_CA_CERT_PATH=
RED_AGENT_CA_KEY_PATH=
RED_AGENT_LLM_TRIAGE_ENABLED=false
RED_AGENT_LLM_TRIAGE_MODEL=
RED_AGENT_SEMANTIC_DEDUP_ENABLED=false
RED_AGENT_BUG_BOUNTY_MODE=false

# ── Backstage catalog / TechDocs source resolution ────────────────────────
# The Backstage exporter advertises each plugin's docs via a techdocs-ref in
# ONE of two modes. Pick the one that matches your deploy topology.
#
# GIT mode (default): the exporter emits an "url:" ref under this base, and the
# portal's TechDocs generator fetches the plugin's mkdocs from the git host.
# The public repo below needs no token; a PRIVATE fork would need a GITHUB_TOKEN
# integration in the portal app-config AND the docs pushed to the referenced
# branch — otherwise the Docs tab 404s (api.github.com/repos/.../status 404).
BASELITH_CATALOG_SOURCE_LOCATION=url:https://github.com/baselithcore/baselithcore/blob/main/
#
# LOCAL mode (self-hosted single-host deploy where the framework backend and the
# portal share the repo filesystem): set this to the ABSOLUTE repo root on that
# host. The exporter then emits "techdocs-ref: dir:." + a "file:" location, so
# the portal's generator builds docs straight from local disk — no git host,
# token or push needed. Leave EMPTY to stay in git mode above.
#   BASELITH_CATALOG_LOCAL_ROOT=/opt/baselithcore
BASELITH_CATALOG_LOCAL_ROOT=
