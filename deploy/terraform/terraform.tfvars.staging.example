# Staging overlay — provisions the TRL 5 "relevant environment" (V&V plan §3).
# Copy to terraform.tfvars (gitignored) and fill in, or keep both examples and
# apply with:  terraform apply -var-file=terraform.tfvars.staging
#
# Release name "baselithcore-staging" makes the Terraform-managed Secret
# "baselithcore-staging-secrets" — exactly the existingSecret referenced by
# values-staging.yaml.

kubeconfig_path = "~/.kube/config"
kube_context    = ""            # empty = current context
namespace       = "baselithcore-staging"
release_name    = "baselithcore-staging"
image_tag       = "0.16.0"

# The staging overlay shipped with the chart (fixed capacity, observability
# on, real LLM provider — see mkdocs-site/docs/validation/campaigns.md).
values_files = ["../helm/baselithcore/values-staging.yaml"]

# Non-sensitive overrides. Set the real staging hostname here.
set_values = {
  "ingress.hosts[0].host"     = "staging.example.com"
  "ingress.tls[0].hosts[0]"   = "staging.example.com"
}

# Sensitive — keep this file out of version control.
app_secrets = {
  SECRET_KEY           = "REPLACE_WITH_64_CHAR_RANDOM"
  DATA_ENCRYPTION_KEYS = "v1:REPLACE_WITH_BASE64_32B_KEY"
  DB_PASSWORD          = "REPLACE"
  ANTHROPIC_API_KEY    = "REPLACE"   # campaigns require a real provider (V5)
}
