# =============================================================================
# Base Configuration - Baselith-Core (White-Label)
# =============================================================================
# This file contains shared settings used across all environments.
# Copy and customize for your deployment (e.g., cp configs/.env.base .env).
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings (CORE_ prefix)
# -----------------------------------------------------------------------------
CORE_APP_NAME=Baselith-Core
CORE_DEBUG=false
CORE_MAX_WORKERS=4
CORE_PLUGIN_DIR=plugins
CORE_DATA_DIR=data
CORE_DOCUMENTS_DIR=documents
CORE_DETERMINISTIC_MODE=false
CORE_RANDOM_SEED=42

# -----------------------------------------------------------------------------
# LLM Settings (LLM_ prefix)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama                # ollama, openai, huggingface
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=
LLM_API_KEY=                      # API key for provider (e.g. OpenAI)
LLM_API_BASE=                      # Base URL for API (e.g. for Ollama)
LLM_ENABLE_CACHE=true
LLM_CACHE_TTL=3600
LLM_CACHE_MAX_SIZE=1000

# -----------------------------------------------------------------------------
# HuggingFace Settings (within LLMConfig)
# -----------------------------------------------------------------------------
LLM_HUGGINGFACE_LOCAL=false        # Use local transformers instead of Inference API
LLM_HUGGINGFACE_DEVICE=auto        # auto, cpu, cuda, mps
LLM_HUGGINGFACE_DTYPE=auto         # auto, float16, bfloat16, float32
LLM_HUGGINGFACE_TRUST_REMOTE_CODE=false
HF_TOKEN=                          # Required for some private models

# -----------------------------------------------------------------------------
# Vision Service (VISION_ prefix)
# -----------------------------------------------------------------------------
VISION_PROVIDER=openai             # openai, anthropic, google, ollama
VISION_OPENAI_API_KEY=
VISION_ANTHROPIC_API_KEY=
VISION_GOOGLE_API_KEY=
VISION_OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Voice Service (VOICE_ prefix)
# -----------------------------------------------------------------------------
VOICE_PROVIDER=openai              # openai, elevenlabs, google
VOICE_OPENAI_API_KEY=
VOICE_ELEVENLABS_API_KEY=
VOICE_GOOGLE_API_KEY=
VOICE_GOOGLE_APPLICATION_CREDENTIALS=
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Fine-Tuning Service (FINETUNE_ prefix)
# -----------------------------------------------------------------------------
FINETUNE_OPENAI_API_KEY=
FINETUNE_TOGETHER_API_KEY=

# -----------------------------------------------------------------------------
# VectorStore Settings (VECTORSTORE_ prefix)
# -----------------------------------------------------------------------------
VECTORSTORE_PROVIDER=qdrant
VECTORSTORE_COLLECTION_NAME=documents
VECTORSTORE_QDRANT_HOST=localhost
VECTORSTORE_PORT=6333
VECTORSTORE_GRPC_PORT=6334
VECTORSTORE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTORSTORE_EMBEDDING_DIM=384
EMBEDDING_CACHE_TTL=3600
VECTORSTORE_SEARCH_LIMIT=10
VECTORSTORE_QDRANT_MODE=server
EMBEDDING_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Chat Service (CHAT_ prefix)
# -----------------------------------------------------------------------------
CHAT_STREAMING_ENABLED=true
CHAT_INITIAL_SEARCH_K=20
CHAT_FINAL_TOP_K=5
CHAT_MAX_HISTORY_LENGTH=10
CHAT_ENABLE_RERANKING=true
CHAT_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHAT_RERANK_MAX_CANDIDATES=50
CHAT_ENABLE_RESPONSE_CACHE=true
CHAT_RESPONSE_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Storage & Databases (Postgres, GraphDB, Redis)
# -----------------------------------------------------------------------------
POSTGRES_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baselithcore
DB_USER=baselithcore
DB_PASSWORD=baselithcore
DB_SSL_MODE=disable
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_POOL_TIMEOUT=30.0

GRAPH_DB_ENABLED=true
GRAPH_DB_URL=redis://localhost:6379
GRAPH_DB_NAME=agent_graph
GRAPH_RAG_ENABLED=false
GRAPH_DB_TIMEOUT=2.0
GRAPH_SIMILAR_TOP_K=5
GRAPH_CACHE_TTL=3600
GRAPH_QUERY_LIMIT=30
GRAPH_MAX_HOPS=3
GRAPH_QUERY_TIMEOUT=5.0

CACHE_BACKEND=local               # local, redis
CACHE_REDIS_URL=redis://localhost:6379/1
CACHE_REDIS_PREFIX=baselithcore
QUEUE_REDIS_URL=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Processing (OCR, Web, NLP)
# -----------------------------------------------------------------------------
DOCUMENTS_EXTENSIONS='[".md", ".markdown", ".pdf", ".docx", ".doc", ".xlsx", ".xls", ".pptx", ".ppt", ".png", ".jpg", ".jpeg", ".gif", ".webp", ".tif", ".tiff"]'
WEB_DOCUMENTS_ENABLED=false
WEB_DOCUMENTS_URLS='[]'
WEB_DOCUMENTS_MAX_PAGES=5
WEB_DOCUMENTS_MAX_DEPTH=2
WEB_DOCUMENTS_RENDER_TIMEOUT=20.0
WEB_DOCUMENTS_USER_AGENT="Mozilla/5.0..."
WEB_DOCUMENTS_ALLOWLIST='[]'
ENABLE_SPACY_DOCUMENTS=true
SPACY_MODEL=en_core_web_sm
SPACY_FALLBACK_LANGUAGE=
PDF_OCR_BACKEND=chandra            # chandra, tesseract, auto

# Chandra OCR Specific
CHANDRA_OCR_METHOD=vllm            # vllm, hf
# CHANDRA_MAX_OUTPUT_TOKENS=
# CHANDRA_MAX_WORKERS=
# CHANDRA_MAX_RETRIES=
CHANDRA_INCLUDE_HEADERS_FOOTERS=false
CHANDRA_VLLM_API_BASE=
CHANDRA_VLLM_API_KEY=
CHANDRA_VLLM_MODEL_NAME=

# Logging
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=INFO
LOG_JSON=true
LOG_MASKING_ENABLED=true

# Telemetry
TELEMETRY_ENABLED=false
TELEMETRY_OTEL_ENDPOINT=http://localhost:4317

APP_TIMEZONE=Europe/Rome
ENABLE_FEEDBACK=true
LLM_BUDGET_ENABLED=true
LLM_BUDGET_MAX_TOKENS=10000

CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_MAX_TURNS=6
CHAT_MEMORY_SUMMARY_ENABLED=true

CHAT_GUARDRAILS_ENABLED=true
CHAT_GUARDRAILS_BLOCK_MESSAGE="I cannot assist you with this request."
CHAT_GUARDRAILS_OUT_OF_SCOPE_MESSAGE="I can only answer questions related to the indexed documents."

# BASELITHCORE_API_URL=
# BASELITHCORE_ENABLE_FEEDBACK=true

# -----------------------------------------------------------------------------
# Plugin System (PLUGIN_ prefix)
# -----------------------------------------------------------------------------
PLUGIN_ENABLED=true
PLUGIN_AUTO_LOAD=true
PLUGIN_CONFIG_PATH=configs/plugins.yaml

# -----------------------------------------------------------------------------
# Sandbox Service (SANDBOX_ prefix)
# -----------------------------------------------------------------------------
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=30
SANDBOX_ENABLE_NETWORK=false
# SANDBOX_DOCKER_SOCKET=/var/run/docker.sock

# -----------------------------------------------------------------------------
# Advanced Reasoning - Tree of Thoughts (TOT_ prefix)
# -----------------------------------------------------------------------------
TOT_MAX_DEPTH=3
TOT_BRANCHING_FACTOR=3
TOT_BEAM_WIDTH=3
TOT_STRATEGY=bfs                   # bfs, dfs

# Self-correction
TOT_SELF_CORRECTION_MAX_ITERATIONS=2

# Thought Cache
TOT_THOUGHT_CACHE_MAXSIZE=1000
TOT_THOUGHT_CACHE_TTL=1800.0

# -----------------------------------------------------------------------------
# Resilience (RESILIENCE_ prefix)
# -----------------------------------------------------------------------------
# Circuit Breaker
RESILIENCE_CB_FAIL_MAX=5
RESILIENCE_CB_RESET_TIMEOUT=60
RESILIENCE_CB_HALF_OPEN_MAX=1

# Retry
RESILIENCE_RETRY_MAX_ATTEMPTS=3
RESILIENCE_RETRY_BASE_DELAY=1.0
RESILIENCE_RETRY_MAX_DELAY=60.0
RESILIENCE_RETRY_EXPONENTIAL_BASE=2.0
RESILIENCE_RETRY_JITTER=true

# Bulkhead
RESILIENCE_BULKHEAD_MAX_CONCURRENT=10

# Rate Limiting
RESILIENCE_API_RATE_LIMIT=100
RESILIENCE_API_RATE_WINDOW=60
RESILIENCE_LLM_RATE_LIMIT=20
RESILIENCE_LLM_RATE_WINDOW=60

# -----------------------------------------------------------------------------
# Security & Auth
# -----------------------------------------------------------------------------
AUTH_REQUIRED=false
SECRET_KEY=
ALLOW_ORIGINS=["*"]
API_KEYS_USER=[]
API_KEYS_ADMIN=[]
API_KEYS_JOB=[]

ADMIN_USER=admin
ADMIN_PASS=password
