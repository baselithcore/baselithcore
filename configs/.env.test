# =============================================================================
# Test Configuration
# =============================================================================
# Extends .env.base with test-specific settings.
# Used automatically by pytest.
# =============================================================================

CORE_DEBUG=true

# Logging
LOG_LEVEL_CONSOLE=WARNING
LOG_LEVEL_FILE=WARNING
LOG_JSON=false
LOG_MASKING_ENABLED=true

CORE_DATA_DIR=test_data
CORE_DOCUMENTS_DIR=test_documents
CORE_PLUGIN_DIR=test_plugins
CORE_DETERMINISTIC_MODE=true
CORE_RANDOM_SEED=42

# LLM Mock/Test
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_OLLAMA_URL=http://localhost:11434
LLM_CACHE_ENABLED=false
LLM_BUDGET_ENABLED=false
LLM_TEMPERATURE=0.0

# HuggingFace Test
HF_TOKEN=dummy
LLM_HUGGINGFACE_LOCAL=false

# Storage Test
VECTORSTORE_QDRANT_COLLECTION=test_documents
POSTGRES_ENABLED=true
DB_NAME=test_baselithcore
GRAPH_DB_ENABLED=false

# Cache
CACHE_BACKEND=memory
# CACHE_REDIS_URL=redis://localhost:6379/1
# QUEUE_REDIS_URL=redis://localhost:6379/2
CHAT_RESPONSE_CACHE_ENABLED=false
GRAPH_RAG_ENABLED=false
AUTH_REQUIRED=false

# Plugins
PLUGIN_AUTO_LOAD=false

# Security
API_KEY_ENABLED=false
ALLOW_ORIGINS=["*"]
