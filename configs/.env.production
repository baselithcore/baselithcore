# =============================================================================
# Production Configuration
# =============================================================================
# Extends .env.base with production-specific settings.
# Copy to .env for production deployment.
# SECURITY: Review all settings before deploying!
# =============================================================================

CORE_DEBUG=false
CORE_MAX_WORKERS=8

# Logging
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=INFO
LOG_JSON=true
LOG_MASKING_ENABLED=true
TELEMETRY_ENABLED=true

# LLM Production
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_OPENAI_API_KEY=${OPENAI_API_KEY:-}
LLM_BUDGET_ENABLED=true
LLM_BUDGET_MAX_TOKENS=500000

# HuggingFace Prod
HF_TOKEN=
LLM_HUGGINGFACE_LOCAL=false

# Storage Production
VECTORSTORE_QDRANT_HOST=${QDRANT_HOST:-localhost}
DB_HOST=${DB_HOST}
DB_PASSWORD=${DB_PASSWORD}
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_SIZE=5
CACHE_BACKEND=redis
CACHE_REDIS_URL=redis://falkordb:6379/1
CACHE_REDIS_PREFIX=baselithcore_prod
QUEUE_REDIS_URL=redis://falkordb:6379/2
GRAPH_DB_ENABLED=true
GRAPH_DB_URL=redis://falkordb:6379

# Plugins
# Set to false if you want to explicitly load plugins via config
PLUGIN_AUTO_LOAD=true

# Security
API_KEY_ENABLED=true
API_KEY=${API_KEY:-}
SECRET_KEY=${SECRET_KEY}
ALLOW_ORIGINS=["https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
AUTH_REQUIRED=true
CHAT_GUARDRAILS_ENABLED=true

# Marketplace & Registry
# Optional API key for authenticating with the hub
MARKETPLACE_API_KEY=
