# =============================================================================
# Development Configuration
# =============================================================================
# Extends .env.base with development-specific settings.
# Copy to .env for local development.
# =============================================================================

CORE_DEBUG=true

# Logging
LOG_LEVEL_CONSOLE=DEBUG
LOG_LEVEL_FILE=DEBUG
LOG_JSON=false
LOG_MASKING_ENABLED=true
TELEMETRY_ENABLED=false

# LLM Development
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_BASE=http://localhost:11434

# Vision Development
VISION_PROVIDER=ollama
VISION_OLLAMA_HOST=http://localhost:11434
LLM_ENABLE_CACHE=true
LLM_TEMPERATURE=0.8

# Storage Development
POSTGRES_ENABLED=true
DB_HOST=localhost
GRAPH_DB_ENABLED=true

# Cache
CACHE_BACKEND=local
# CACHE_REDIS_URL=redis://localhost:6379/1
# QUEUE_REDIS_URL=redis://localhost:6379/2

# Plugins
PLUGIN_ENABLED=true
PLUGIN_AUTO_LOAD=true

# Security (Development - permissive)
AUTH_REQUIRED=false
ALLOW_ORIGINS=["*"]
CHAT_GUARDRAILS_ENABLED=false
CORE_DETERMINISTIC_MODE=false
