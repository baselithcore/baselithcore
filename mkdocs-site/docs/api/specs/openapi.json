  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "conversation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversation Id"
          },
          "stream": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stream",
            "default": false
          },
          "rag_only": {
            "type": "boolean",
            "title": "Rag Only",
            "default": false
          },
          "kb_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Kb Label"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": ["query"],
        "title": "ChatRequest",
        "description": "Request model for the agent.\nContains the user query and, optionally, the conversation_id.\nThe `stream` flag is accepted for compatibility, but the dedicated\nstreaming endpoint is `/chat/stream`."
      },
      "CreateTenantRequest": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": ["id", "name"],
        "title": "CreateTenantRequest",
        "description": "Payload for creating a new tenant."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "InstallRequest": {
        "properties": {
          "version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Version",
            "description": "Specific version to install"
          },
          "force": {
            "type": "boolean",
            "title": "Force",
            "description": "Whether to overwrite existing",
            "default": false
          }
        },
        "type": "object",
        "title": "InstallRequest",
        "description": "Request schema for plugin installation."
      },
      "Tenant": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": ["id", "name", "status", "created_at"],
        "title": "Tenant",
        "description": "Data model representing a system tenant.\n\nAttributes:\n    id: Unique tenant identifier (slug).\n    name: Human-readable display name.\n    status: Operational status (active, suspended, etc.).\n    created_at: ISO timestamp of creation."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBasic": {
        "type": "http",
        "scheme": "basic"
      }
    }
  }
}
