    "/reindex": {
      "post": {
        "tags": ["indexing"],
        "summary": "Reindex",
        "description": "Performs an incremental indexing of local documents (synchronous operation).\n- Markdown files are read from the folder configured in ``DOCUMENTS_PATH`` (.env)\n- Paths and vector store parameters are defined via .env (QDRANT_PATH, COLLECTION_NAME)",
