    "/feedbacks": {
      "get": {
        "tags": ["feedback"],
        "summary": "List Feedbacks",
        "description": "Returns all saved feedback entries.\n- If `feedback` is specified, filters by type ('positive' or 'negative').",
        "operationId": "list_feedbacks_feedbacks_get",
        "parameters": [
          {
            "name": "feedback",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": ["positive", "negative"],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter results by feedback type: 'positive' or 'negative'",
              "title": "Feedback"
            },
            "description": "Filter results by feedback type: 'positive' or 'negative'"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 200,
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Limit the number of returned records (max 200)",
              "title": "Limit"
            },
            "description": "Limit the number of returned records (max 200)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  },
