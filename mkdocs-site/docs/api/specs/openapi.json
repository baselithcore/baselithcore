    "/admin/data": {
      "get": {
        "tags": ["admin"],
        "summary": "Admin Data",
        "description": "Returns analytics/feedback data in JSON format (protected by Basic Auth).\n- Aggregated totals (positive, negative, percentages)\n- Daily time series\n- Recent feedback with metadata and sources\n- Most cited queries and documents in the selected period",
        "operationId": "admin_data_admin_data_get",
        "security": [
          {
            "HTTPBasic": []
          }
        ],
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 365,
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Time window (in days) to consider for analytics. Use values >0.",
              "default": 30,
              "title": "Days"
            },
            "description": "Time window (in days) to consider for analytics. Use values >0."
          },
          {
            "name": "recent_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Number of recent feedbacks to return.",
              "default": 20,
              "title": "Recent Limit"
            },
            "description": "Number of recent feedbacks to return."
          },
          {
            "name": "top_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 50,
              "minimum": 1,
              "description": "Maximum number of entries for popular queries/documents.",
              "default": 10,
              "title": "Top Limit"
            },
            "description": "Maximum number of entries for popular queries/documents."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
