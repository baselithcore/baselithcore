{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {"type": "fix", "release": "patch"},
          {"type": "feat", "release": "minor"},
          {"type": "perf", "release": "patch"},
          {"type": "refactor", "release": false},
          {"type": "docs", "release": false},
          {"type": "chore", "release": false},
          {"type": "ci", "release": false},
          {"type": "test", "release": false}
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this project are documented here. This file is\nmaintained automatically by semantic-release from Conventional Commits and\nfollows [Keep a Changelog](https://keepachangelog.com) and\n[Semantic Versioning](https://semver.org)."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "python - <<'PY'\nfrom pathlib import Path\npath = Path('core/_version.py')\npath.write_text('\"\"\"Single source of truth for the framework version.\"\"\"\\n\\n__version__ = \"${nextRelease.version}\"\\n', encoding='utf-8')\nPY"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["core/_version.py", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
