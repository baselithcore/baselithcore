# RAG System Environment
# Copy to .env and customize

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
