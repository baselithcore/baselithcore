# Environment for the BaselithCore Backstage portal systemd service.
# Copy to /etc/baselith/backstage-portal.env and edit the values below.
# Loaded by backstage-portal.service (EnvironmentFile=).

# --- Browser-reachable URLs (set to the deployment host IP) ------------------
# APP_BASE_URL is the frontend origin AND the backend CORS origin — they must
# match. The dev server binds to this host:port, so the host must own the IP.
APP_BASE_URL=http://YOUR_HOST_IP:3010
# Backend URL the SPA (running in a browser on another machine) calls.
BACKEND_BASE_URL=http://YOUR_HOST_IP:7007

# --- BaselithCore the entity provider syncs from (server-side) ---------------
# Same host as the portal → localhost is correct and fastest.
BASELITH_BASE_URL=http://localhost:8000
# Must match an admin/job API key configured in BaselithCore.
BASELITH_API_KEY=CHANGE_ME

# --- Optional -----------------------------------------------------------------
# Lock the backend to one interface instead of all (default 0.0.0.0). Leaving
# 0.0.0.0 is required for a browser on another machine to reach :7007.
# BACKEND_LISTEN_HOST=0.0.0.0
